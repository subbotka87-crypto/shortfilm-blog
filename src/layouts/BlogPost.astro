---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { hideMeta?: boolean };

const { title, description, pubDate, updatedDate, heroImage, hideMeta = false } = Astro.props;
---

<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				position: relative;
			}
			.hero-image img {
				display: block;
				width: 100%;
				margin: 0;
				border-radius: 0;
				max-height: 460px;
				object-fit: cover;
			}
			.hero-image::after {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(180deg, rgba(13, 17, 23, 0%) 40%, var(--bg) 100%);
			}
			.back-link {
				display: block;
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 1.5em auto 0;
				color: rgb(var(--gray));
				text-decoration: none;
				font-size: 0.85em;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}
			.back-link:hover {
				color: var(--accent);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
				font-size: 1.05em;
				line-height: 1.85;
			}
			.title {
				margin-bottom: 1.5em;
				padding: 0.5em 0 1.5em;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.85em;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1200} height={460} src={heroImage} alt="" />}
				</div>
				<a class="back-link" href="/blog">← Назад в блог</a>
				<div class="prose">
					<div class="title">
						{
							!hideMeta && (
								<div class="date">
									<FormattedDate date={pubDate} />
									{updatedDate && (
										<div class="last-updated-on">
											Обновлено <FormattedDate date={updatedDate} />
										</div>
									)}
								</div>
							)
						}
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
